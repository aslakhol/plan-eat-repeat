# Clerk Authentication
# Get this from your Clerk dashboard: https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Base URL for the web app API used by Expo Go on a physical phone.
# Use your computer's LAN IP (not localhost), e.g. http://192.168.1.25:3000
EXPO_PUBLIC_API_URL=http://192.168.1.25:3000

# Parity capture (dev only)
EXPO_PUBLIC_PARITY_BYPASS_AUTH=false
EXPO_PUBLIC_PARITY_BYPASS_TOKEN=parity-local-token
# Optional override for parity API target (defaults to http://127.0.0.1:3100 in parity mode)
# EXPO_PUBLIC_PARITY_API_URL=http://127.0.0.1:3100
