# Clerk Authentication
# Get this from your Clerk dashboard: https://dashboard.clerk.com
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# Base URL override for the web app API. Normally leave this commented out —
# the app infers your computer's IP from the Metro connection and assumes
# port 3000. Set it only when that fails or the web server runs on another
# port. Use your LAN IP (not localhost), e.g. http://192.168.1.25:3004
# EXPO_PUBLIC_API_URL=http://192.168.1.25:3000
