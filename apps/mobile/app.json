{
  "expo": {
    "name": "PlanEatRepeat",
    "slug": "planeatrepeat",
    "scheme": "planeatrepeat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PlanEatRepeat to choose photos of recipes.",
          "cameraPermission": "Allow PlanEatRepeat to photograph recipes.",
          "microphonePermission": false
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.planeatrepeat.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.planeatrepeat.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
