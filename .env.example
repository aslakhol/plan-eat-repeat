
# When adding additional environment variables, the schema in "/src/env.mjs"
# should be updated accordingly.

# Prisma
DATABASE_URL=postgres://planeatrepeat:planeatrepeat@localhost:5434/planeatrepeat
DIRECT_URL=postgres://planeatrepeat:planeatrepeat@localhost:5434/planeatrepeat

# Other
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
CLERK_SECRET_KEY=
WEBHOOK_SECRET=

# Parity capture (dev only)
PARITY_BYPASS_AUTH=false
# Optional overrides (when omitted, parity capture auto-selects from local DB)
# PARITY_BYPASS_USER_ID=
# PARITY_BYPASS_HOUSEHOLD_ID=
NEXT_PUBLIC_PARITY_BYPASS_TOKEN=parity-capture
